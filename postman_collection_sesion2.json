{
  "info": {
    "name": "Sesion 2 - Tareas Clima y Auth",
    "_postman_id": "00000000-0000-0000-0000-000000000000",
    "description": "Colección con endpoints de clima, tareas y autenticación (registro, login, perfil).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get clima por ciudad",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://localhost:3000/api/clima/London",
          "protocol": "https",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "clima", "London"]
        },
        "description": "Endpoint independiente que devuelve el clima de una ciudad. Cambia 'London' por otra ciudad si lo deseas."
      },
      "response": []
    },
    {
      "name": "Get tarea + clima",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://localhost:3000/api/tareas/1/clima?ciudad=London",
          "protocol": "https",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "tareas", "1", "clima"],
          "query": [
            {
              "key": "ciudad",
              "value": "London"
            }
          ]
        },
        "description": "Endpoint combinado que devuelve una tarea y el clima para la ciudad indicada en el parámetro ciudad."
      },
      "response": []
    },
    {
      "name": "Validación 400 (caracteres inválidos)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://localhost:3000/api/clima/London!!",
          "protocol": "https",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "clima", "London!!"]
        },
        "description": "Prueba de validación: debe devolver 400 porque !! no son caracteres válidos."
      },
      "response": []
    },
    {
      "name": "Auth - Registro",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Alumno\",\n  \"correo\": \"alumno@demo.com\",\n  \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://localhost:3000/api/auth/registro",
          "protocol": "https",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "auth", "registro"]
        },
        "description": "Registra un usuario nuevo para autenticación."
      },
      "response": []
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"correo\": \"alumno@demo.com\",\n  \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://localhost:3000/api/auth/login",
          "protocol": "https",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "auth", "login"]
        },
        "description": "Inicia sesión y devuelve un token JWT.",
        "auth": { "type": "noauth" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.token) {",
              "  pm.environment.set('token', response.token);",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "Auth - Perfil",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "https://localhost:3000/api/auth/perfil",
          "protocol": "https",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "auth", "perfil"]
        },
        "description": "Obtiene el perfil del usuario usando el token JWT guardado en la variable de entorno.",
        "auth": { "type": "noauth" }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://localhost:3000",
      "type": "string"
    },
    {
      "key": "ciudad",
      "value": "London",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
